```{=html}
<% for (const item of items) { %>
    <h3>Занятие <%= item.number %></h3>
    <p>
        <% 
            var links = [];
            if(item.lectures) { links.push('<a href="' + item.lectures + '">📄 Презентация</a>'); }
            if(item.lectures_en) { links.push('<a href="' + item.lectures_en + '">📄 Presentation</a>'); }
            if(item.notes) { links.push('<a href="' + item.notes + '">📝 Заметки</a>'); }
            if(item.notes_1group) { links.push('<a href="' + item.notes_1group + '">📝 Заметки 1 поток</a>'); }
            if(item.notes_2group) { links.push('<a href="' + item.notes_2group + '">📝 Заметки 2 поток</a>'); }
            if(item.youtube) { links.push('<a href="' + item.youtube + '">▶️ Youtube</a>'); }
            if(item.download) { links.push('<a href="' + item.download + '">💿 Скачать</a>'); }
            print(links.join(' • '));
        %>
    </p>
    <p><%= item.title %></p>
<% } %>
```
